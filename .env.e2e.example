# Copie este arquivo para .env.e2e.local e preencha com um usuário real de teste.
# .env.e2e.local é ignorado pelo Git e carregado automaticamente pelo Playwright.

# URL testada pelo Playwright. Deixe vazio para subir o dev server local.
# E2E_BASE_URL=https://deniaros.vercel.app
E2E_BASE_URL=http://127.0.0.1:3000

# Porta usada quando E2E_BASE_URL não for definido.
E2E_PORT=3000

# Cliente de teste autenticado.
# Crie este usuário no Supabase Auth e garanta que ele tenha um workspace limpo.
E2E_USER_EMAIL=cliente.e2e@seudominio.com
E2E_USER_PASSWORD=troque-esta-senha

# Use 0 para navegação segura. Use 1 apenas quando quiser criar dados no workspace de teste.
E2E_ALLOW_MUTATION=0
